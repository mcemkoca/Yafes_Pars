# AssureManager Environment Configuration
# Copy to .env.local and customize for your environment

# SQL Server Configuration
DB_SERVER=localhost
DB_NAME=AssureManagerDB
DB_USER=sa
DB_PASSWORD=YourStrong@Passw0rd
DB_PORT=1433

# API Configuration
PORT=3001
NODE_ENV=development

# Frontend API URL (for browser)
REACT_APP_API_URL=http://localhost:3001/api/v1

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:3000
